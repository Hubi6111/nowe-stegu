# ════════════════════════════════════════════════════════
#  Stegu Visualizer — Environment Template
#  Copy this to .env and paste your Gemini API key.
#
#  DO NOT commit .env — it contains your secret key.
# ════════════════════════════════════════════════════════

# ── Gemini (server-side only — never exposed to browser) ─
GEMINI_API_KEY=
# Image output — photorealistic render (latest image gen model)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Vision + JSON — mask detection & scene analysis (best stable)
GEMINI_REASONING_MODEL=gemini-2.5-pro
# Optional overrides: GEMINI_TEXT_MODEL, GEMINI_FLASH_MODEL

# ── Service URLs ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000
INFERENCE_BASE_URL=http://localhost:8001

# ── Internal aliases (used by api/ code) ─────────────────
API_PROXY_URL=http://localhost:8000
INFERENCE_URL=http://localhost:8001

# ── Paths (relative to project root) ─────────────────────
TEXTURES_DIR=./assets/textures/stegu
DATA_DIR=./data
MODEL_CACHE_DIR=./data/model-cache

# ── Texture scale (optional — realistic brick size vs photo) ─
# Typical EU interior wall height used for mm→pixel calibration (mm).
# STEGU_ASSUMED_WALL_HEIGHT_MM=2850
# Global multiplier on tile scale (<1 = smaller bricks). Overrides per-product meta when set.
# STEGU_TEXTURE_SCALE_MULTIPLIER=1.0
